{
  "type": "record",
  "name": "GameOver",
  "namespace": "rotr.events",
  "doc": "End-of-stream event on game.broadcast. Produced with enable.idempotence=true so it appears EXACTLY ONCE even across an engine crash (spec §13).",
  "fields": [
    { "name": "winner", "type": "string" },
    { "name": "cause", "type": "string" },
    { "name": "turn", "type": "int" },
    { "name": "timestamp", "type": "long" }
  ]
}
